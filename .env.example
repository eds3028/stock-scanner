# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Australia/Perth

# ── Ollama (optional - enables AI narrative generation) ───────────────────────
# Point at your Ollama instance, e.g. http://192.168.1.10:11434
# Leave blank to disable narrative generation.
OLLAMA_HOST=
OLLAMA_MODEL=llama3.1:8b

# ── Universe (optional - controls which tickers are scanned) ─────────────────
# Options: asx20, asx200, watchlist, or any key defined in config/universe.yaml
# Defaults to the 'active' key in universe.yaml (currently: asx200)
UNIVERSE=asx200

# ── Data providers (all optional - yahooquery works without any keys) ──────────
# Finnhub: https://finnhub.io  (free tier available)
FINNHUB_API_KEY=

# Financial Modelling Prep: https://financialmodelingprep.com  (free tier available)
FMP_API_KEY=

# Alpha Vantage: https://www.alphavantage.co  (free tier available, limited ASX coverage)
ALPHA_VANTAGE_API_KEY=
